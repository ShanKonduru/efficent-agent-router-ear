# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Required: OpenRouter API key for fetching model metadata and routing calls
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Registry cache TTL in seconds (default: 300)
EAR_REGISTRY_TTL_SECONDS=300

# Optional: Default budget priority - low | medium | high (default: medium)
EAR_DEFAULT_BUDGET=medium

# Optional: Maximum retry attempts per model before cascading (default: 3)
EAR_MAX_RETRIES=3

# Optional: OpenRouter base URL (default: https://openrouter.ai/api/v1)
EAR_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: HTTP request timeout in seconds (default: 30)
EAR_REQUEST_TIMEOUT_SECONDS=30
